 }
 
+/* Section card — high-contrast surface with left accent stripe */
+.section-card {
+  position: relative;
+  background: var(--card);
+  border: 1px solid var(--border);
+  border-radius: 1rem;
+  padding: 1.25rem;
+  box-shadow: 0 1px 0 oklch(1 0 0 / 6%) inset, 0 12px 30px -18px oklch(0 0 0 / 60%);
+}
+.section-card::before {
+  content: '';
+  position: absolute;
+  inset: 0 auto 0 0;
+  width: 3px;
+  border-radius: 1rem 0 0 1rem;
+  background: var(--section-accent, var(--primary));
+  opacity: 0.9;
+}
+.section-card.section-team { --section-accent: var(--section-team); }
+.section-card.section-strategy { --section-accent: var(--section-strategy); }
+.section-card.section-changes { --section-accent: var(--section-changes); }
+
+/* Inner tiles inside a card (higher contrast than card bg) */
+.tile {
+  background: var(--card-elevated);
+  border: 1px solid var(--border);
+  border-radius: 0.6rem;
+}
+
 /* Card hover lift */
 .card-lift {
   transition: transform 220ms cubic-bezier(.2,.7,.2,1), box-shadow 220ms, border-color 220ms;
